      "source": [
        "from google.colab import files\n",
        "from PIL import Image\n",
        "import numpy as np\n",
        "import io\n",
        "import tensorflow as tf\n",
        "\n",
        "# 1. Preparation: Ensure we have class names and settings\n",
        "if 'class_names' not in locals():\n",
        "    class_names = valid_data.class_names\n",
        "\n",
        "IMG_SIZE = (224, 224)\n",
        "tflite_model_path = 'plant_disease_classifier.tflite'\n",
        "\n",
        "# 2. Upload images\n",
        "uploaded = files.upload()\n",
        "\n",
        "for fn in uploaded.keys():\n",
        "    print(f'\\nProcessing \"{fn}\"...')\n",
        "    img_bytes = uploaded[fn]\n",
        "    img = Image.open(io.BytesIO(img_bytes)).convert('RGB')\n",
        "    img = img.resize(IMG_SIZE)\n",
        "\n",
        "    # Convert to array and scale to [-1, 1] as done in the Rescaling layer\n",
        "    img_array = np.array(img).astype(np.float32)\n",
        "    input_data = (img_array / 127.5) - 1.0\n",
        "    input_data = np.expand_dims(input_data, axis=0)\n",
        "\n",
        "    # --- Method A: Keras Model Prediction (Control) ---\n",
        "    if 'model' in locals():\n",
        "        keras_preds = model.predict(input_data, verbose=0)\n",
        "        k_idx = np.argmax(keras_preds[0])\n",
        "        print(f\"Keras Model: {class_names[k_idx]} ({keras_preds[0][k_idx]*100:.2f}%)\")\n",
        "\n",
        "    # --- Method B: TFLite Prediction ---\n",
        "    interpreter = tf.lite.Interpreter(model_path=tflite_model_path)\n",
        "    interpreter.allocate_tensors()\n",
        "\n",
        "    input_details = interpreter.get_input_details()\n",
        "    output_details = interpreter.get_output_details()\n",
        "\n",
        "    interpreter.set_tensor(input_details[0]['index'], input_data)\n",
        "    interpreter.invoke()\n",
        "\n",
        "    output_data = interpreter.get_tensor(output_details[0]['index'])\n",
        "\n",
        "    # Check if we need to apply softmax (if the TFLite output looks like raw logits)\n",
        "    if np.max(output_data[0]) > 1.0 or np.min(output_data[0]) < 0.0:\n",
        "        probabilities = tf.nn.softmax(output_data[0]).numpy()\n",
        "    else:\n",
        "        probabilities = output_data[0]\n",
        "\n",
        "    t_idx = np.argmax(probabilities)\n",
        "    print(f\"TFLite Model: {class_names[t_idx]} ({probabilities[t_idx]*100:.2f}%)\")\n",
