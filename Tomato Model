      "source": [
        "import matplotlib.pyplot as plt\n",
        "import numpy as np\n",
        "\n",
        "# Helper to visualize a variety of classes\n",
        "def visualize_model_predictions(dataset, model, class_names, num_images=9):\n",
        "    plt.figure(figsize=(15, 10))\n",
        "    # Take one batch\n",
        "    for images, labels in dataset.take(1):\n",
        "        # Rescale the same way as training/inference\n",
        "        # Note: The model Sequential already includes a Rescaling layer,\n",
        "        # but if we are passing raw data, we must be careful.\n",
        "        # Since the 'model' has a Rescaling layer, we pass 0-255 if it expects it.\n",
        "        # However, our manual test cell used (img/127.5)-1.0.\n",
        "\n",
        "        preds = model.predict(images)\n",
        "\n",
        "        for i in range(num_images):\n",
        "            ax = plt.subplot(3, 3, i + 1)\n",
        "            # Convert tensor to image for display\n",
        "            display_img = images[i].numpy().astype(\"uint8\")\n",
        "            plt.imshow(display_img)\n",
        "\n",
        "            actual_idx = np.argmax(labels[i])\n",
        "            pred_idx = np.argmax(preds[i])\n",
        "            conf = np.max(preds[i]) * 100\n",
        "\n",
        "            color = 'green' if actual_idx == pred_idx else 'red'\n",
        "            plt.title(f\"Actual: {class_names[actual_idx]}\\nPred: {class_names[pred_idx]} ({conf:.1f}%)\", color=color)\n",
        "            plt.axis(\"off\")\n",
        "    plt.tight_layout()\n",
        "    plt.show()\n",
        "\n",
        "visualize_model_predictions(valid_data, model, class_names)"
      ],
