        "    print(\"Top 3 TFLite:\")\n",
        "    top_indices = np.argsort(probabilities)[::-1][:3]\n",
        "    for i in top_indices:\n",
        "        print(f\"  - {class_names[i]}: {probabilities[i]*100:.2f}%\")"
