        "# 1. Create the Base Model from MobileNetV2\n",
        "# set include_top=False to remove Google's original 1000-class classifier\n",
        "base_model = tf.keras.applications.MobileNetV2(\n",
        "    input_shape=IMG_SIZE + (3,), # define the image size for the model\n",
        "    include_top=False, # delete the last layers\n",
        "    weights='imagenet'\n",
        ")\n",
        "\n",
        "# 2. Freeze the base model\n",
        "# This prevents the pre-trained weights from being changed during the first phase\n",
        "base_model.trainable = False\n",
        "\n",
        "# 3. Build the full model\n",
        "model = tf.keras.Sequential([\n",
        "    tf.keras.layers.Rescaling(1./127.5, offset=-1), # Preprocessing: scales pixels to [-1, 1]\n",
        "    base_model,\n",
        "    tf.keras.layers.GlobalAveragePooling2D(),       # Pooling: simplifies the data\n",
        "    tf.keras.layers.Dense(10, activation='softmax') # Output: 10 neurons for your 10 classes\n",
        "])"
